# Copia este archivo como .env y completa los valores reales.
# El archivo .env NUNCA debe subirse al repositorio.

# ── Base de datos Supabase ──────────────────────────────────────────────────
# Usar el pooler IPv4 (Session mode), no la URL directa de la BD (solo IPv6).
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# ── WhatsApp Business API (Meta) ────────────────────────────────────────────
WA_TOKEN=          # Token de acceso permanente de la app de Meta
PHONE_NUMBER_ID=   # ID del número de WhatsApp Business registrado
VERIFY_TOKEN=      # Token arbitrario que configuras en el webhook de Meta

# ── LLM (Groq — plan gratuito) ─────────────────────────────────────────────
GROQ_API_KEY=      # https://console.groq.com → API Keys
